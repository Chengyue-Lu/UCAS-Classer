{
  "name": "ucasclasser-develop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "check": "tsc -p tsconfig.scripts.json --noEmit",
    "auth:reset": "tsx automation/auth/reset.ts",
    "auth:open": "tsx automation/auth/login-and-save-sep.ts",
    "auth:login": "tsx automation/auth/login-and-save-sep.ts",
    "auth:login:legacy": "tsx automation/auth/login-and-save.ts",
    "auth:check": "tsx automation/auth/check-api.ts",
    "auth:check:headed": "tsx automation/auth/check-auth.ts --headed",
    "auth:open-url": "tsx automation/auth/open-authenticated-url.ts",
    "webcheck": "tsx automation/auth/webcheck.ts",
    "download:file": "tsx automation/downloads/download-file.ts",
    "courses:collect": "tsx automation/request-course-list/run-course-list.ts",
    "collect:all": "tsx automation/request-collectors/run-full-collect.ts",
    "runtime:watch": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- watch",
    "runtime:status": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- status",
    "runtime:check": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- check",
    "runtime:clear": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- clear",
    "runtime:login": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- login",
    "runtime:collect": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- collect",
    "runtime:import": "cargo run --quiet --manifest-path src-tauri/Cargo.toml --bin runtime_cli -- import",
    "tauri:dev": "npx tauri dev",
    "tauri:build": "npx tauri build",
    "playwright:install": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
